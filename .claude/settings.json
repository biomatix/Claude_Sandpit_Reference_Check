{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/guard.ps1"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(jobs/**)",
      "Read(memory/**)",
      "Read(.claude/skills/**)",
      "Read(.claude/agents/**)",
      "Read(.claude/commands/**)",
      "Edit(jobs/*/brief.md)",
      "Edit(jobs/*/brief.yaml)",
      "Edit(jobs/*/outputs/**)",
      "Edit(jobs/*/memory/**)",
      "Edit(memory/**)",
      "Edit(MEMORY.md)",
      "Write(jobs/*/brief.md)",
      "Write(jobs/*/brief.yaml)",
      "Write(jobs/*/outputs/**)",
      "Write(jobs/*/memory/**)",
      "Write(memory/**)",
      "WebFetch(domain:doi.org)",
      "WebFetch(domain:api.crossref.org)",
      "WebFetch(domain:api.unpaywall.org)",
      "WebFetch(domain:eutils.ncbi.nlm.nih.gov)",
      "WebFetch(domain:www.ebi.ac.uk)",
      "WebFetch(domain:europepmc.org)",
      "WebFetch(domain:www.biorxiv.org)",
      "WebFetch(domain:biorxiv.org)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:rdrr.io)",
      "WebSearch"
    ]
  },
  "env": {
    "CLAIM_CHECK_EMAIL": "arthur.georges@biomatix.com.au"
  }
}
