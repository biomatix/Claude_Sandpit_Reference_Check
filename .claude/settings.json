{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/guard.ps1"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(jobs/**)",
      "Read(memory/**)",
      "Read(Literature/**)",
      "Read(.claude/skills/**)",
      "Read(.claude/commands/**)",
      "Edit(jobs/*/draft/**)",
      "Edit(jobs/*/outputs/**)",
      "Edit(jobs/*/memory/**)",
      "Edit(memory/**)",
      "Edit(MEMORY.md)",
      "Write(jobs/*/draft/**)",
      "Write(jobs/*/outputs/**)",
      "Write(jobs/*/memory/**)",
      "Write(memory/**)",
      "Write(Literature/**)",
      "WebFetch(domain:doi.org)",
      "WebFetch(domain:api.crossref.org)",
      "WebFetch(domain:api.unpaywall.org)",
      "WebFetch(domain:eutils.ncbi.nlm.nih.gov)",
      "WebFetch(domain:www.ebi.ac.uk)",
      "WebFetch(domain:europepmc.org)",
      "WebFetch(domain:www.biorxiv.org)",
      "WebFetch(domain:biorxiv.org)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:rdrr.io)",
      "WebFetch(domain:georges.biomatix.org)",
      "WebSearch",
      "Bash(curl:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(pandoc:*)",
      "Agent",
      "Task",
      "WebFetch(domain:onlinelibrary.wiley.com)",
      "WebFetch(domain:besjournals.onlinelibrary.wiley.com)",
      "WebFetch(domain:conbio.onlinelibrary.wiley.com)",
      "WebFetch(domain:link.springer.com)",
      "WebFetch(domain:www.publish.csiro.au)",
      "WebFetch(domain:publish.csiro.au)",
      "WebFetch(domain:www.int-res.com)",
      "WebFetch(domain:int-res.com)",
      "WebFetch(domain:academic.oup.com)",
      "WebFetch(domain:www.biomedcentral.com)",
      "WebFetch(domain:pmc.ncbi.nlm.nih.gov)",
      "WebFetch(domain:www.ncbi.nlm.nih.gov)",
      "WebFetch(domain:ncbi.nlm.nih.gov)",
      "WebFetch(domain:scholar.google.com)",
      "Read(D:/workspace/AA_Literature/**)"
    ],
    "additionalDirectories": ["D:/workspace/AA_Literature"]
  },
  "env": {
    "CLAIM_CHECK_EMAIL": "arthur.georges@biomatix.com.au"
  }
}
