# ============================================================
#  Claude_SandPit_Reference_Check — .gitignore
#  Tracks the harness (CLAUDE.md, skills, hooks, commands,
#  manual). Ignores per-manuscript work, the PDF store, and
#  per-machine state.
# ============================================================

# --- R / editor session state -------------------------------
.Rproj.user/
.Rhistory
.Rapp.history
.RData
.Ruserdata

# --- Per-machine Claude Code state --------------------------
.claude/active_job
.claude/settings.local.json
.claude/.credentials.json

# --- Project-level memory ----------------------------------
#  Track the empty MEMORY.md proforma and memory/.gitkeep so
#  fresh clones have the structure CLAUDE.md §7 expects.
#  Ignore every actual memory file written into memory/.
memory/*
!memory/.gitkeep

# --- All per-manuscript work --------------------------------
#  jobs/<slug>/ contains the draft, supplied PDFs, the audit,
#  and per-job memory. None of it is tracked; /new-job creates
#  it on first use.
jobs/

# --- Python bytecode (skills bundle .py helpers) ------------
__pycache__/
*.py[cod]
*$py.class

# --- Backup files -------------------------------------------
*.bak
*.orig

# --- OS / editor cruft --------------------------------------
Thumbs.db
desktop.ini
.DS_Store
.vscode/
.idea/
*.swp
*~

# --- Secrets (defence in depth) -----------------------------
.env
.env.*
*.pem
*.key
*_rsa
*_rsa.pub
